# Copy to .env and adjust as needed.

# SQLAlchemy database URL. Defaults to a local SQLite file.
DATABASE_URL=sqlite:///./vhn.db

# CORS origins allowed to call the API (comma-separated).
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Path to a local GGUF medical model for llama-cpp-python.
# Leave empty to run with the rule-based stub (no model required).
LLM_MODEL_PATH=
